{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build NetworkMonitor",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/NetworkMonitor/NetworkMonitor.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch NetworkMonitor",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/NetworkMonitor/NetworkMonitor.csproj",
        "run"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
