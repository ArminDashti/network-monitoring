{
  "name": "netvan-gui",
  "version": "1.0.0",
  "description": "Modern Windows 11 GUI for Netvan network monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win dir --x64 --config.directories.output=dist-build",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Netvan",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "build": {
    "appId": "com.netvan.gui",
    "productName": "Netvan",
    "directories": {
      "output": "dist-build"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!dist-build/**"
    ]
  }
}
